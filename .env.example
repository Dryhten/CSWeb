# 复制本文件为项目根目录的 .env 后按需修改（.env 勿提交仓库）

# ---------- 后端 npm run start / node server ----------
# 服务监听端口（必填，整数 1–65535）
PORT=3000
# 监听地址：0.0.0.0 允许局域网/公网；仅本机可改为 127.0.0.1
HOST=0.0.0.0

MONGODB_URI=mongodb://localhost:27017/fire-assault
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# ---------- 前端开发 vite（npm run dev -w client）----------
# 可选；未设置时默认 5173
# CLIENT_PORT=5173

# 游戏配置
DEFAULT_MAX_PLAYERS=10
DEFAULT_ROUND_TIME=120
DEFAULT_WIN_SCORE=16

# 房间设置
ROOM_ID_LENGTH=6
ROOM_ID_CHARS=ABCDEFGHJKLMNPQRSTUVWXYZ23456789
