{
  "name": "csweb",
  "version": "1.0.0",
  "private": true,
  "description": "烈火突击 - 全栈 monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev -w @client/fire-assault",
    "dev:server": "npm run dev -w @server/fire-assault",
    "build": "npm run build -w @client/fire-assault",
    "build:client": "npm run build -w @client/fire-assault",
    "preview:client": "npm run preview -w @client/fire-assault",
    "lint": "npm run lint -w @client/fire-assault",
    "fix:client-rollup": "npm install -w @client/fire-assault",
    "start": "npm run build && npm run start -w @server/fire-assault"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
